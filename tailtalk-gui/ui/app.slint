import { Button, CheckBox, ComboBox, LineEdit, GroupBox, HorizontalBox, VerticalBox } from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "TailTalk AFP Server";
    min-width: 400px;
    min-height: 200px;
    preferred-width: 540px;
    preferred-height: 440px;

    in-out property <string> server-name: "TailTalk AFP";
    in property <[string]> ethernet-interfaces;
    in-out property <int> selected-ethernet: 0;
    in property <[string]> tashtalk-ports;
    in-out property <int> selected-tashtalk: 0;
    in-out property <string> volume-path;
    in-out property <string> volume-name: "MacShare";
    in-out property <bool> tashtalk-crc-checking: false;
    in-out property <bool> tashtalk-crc-generation: false;
    in property <bool> running: false;

    // Set from Rust at startup to reflect compiled-in features
    in property <bool> feature-ethertalk: false;
    in property <bool> feature-tashtalk: false;
    in-out property <string> error-message: "";

    callback start-stop();
    callback browse-volume();

    VerticalBox {
        padding: 12px;
        spacing: 8px;

        GroupBox {
            title: "Configuration";

            VerticalBox {
                spacing: 6px;

                HorizontalBox {
                    Text { text: "Server Name:"; min-width: 140px; vertical-alignment: center; }
                    LineEdit {
                        text <=> root.server-name;
                        placeholder-text: "TailTalk AFP";
                        horizontal-stretch: 1;
                        enabled: !root.running;
                    }
                }

                if root.feature-ethertalk : HorizontalBox {
                    Text { text: "Ethernet Interface:"; min-width: 140px; vertical-alignment: center; }
                    ComboBox {
                        model: root.ethernet-interfaces;
                        current-index <=> root.selected-ethernet;
                        horizontal-stretch: 1;
                        enabled: !root.running;
                    }
                }

                if root.feature-tashtalk : HorizontalBox {
                    Text { text: "TashTalk Port:"; min-width: 140px; vertical-alignment: center; }
                    ComboBox {
                        model: root.tashtalk-ports;
                        current-index <=> root.selected-tashtalk;
                        horizontal-stretch: 1;
                        enabled: !root.running;
                    }
                }

                if root.feature-tashtalk : HorizontalBox {
                    Text { text: "TashTalk CRC:"; min-width: 140px; vertical-alignment: center; }
                    CheckBox {
                        text: "Generation";
                        checked <=> root.tashtalk-crc-generation;
                        enabled: !root.running;
                    }
                    CheckBox {
                        text: "Checking";
                        checked <=> root.tashtalk-crc-checking;
                        enabled: !root.running;
                    }
                }

                HorizontalBox {
                    Text { text: "Volume Path:"; min-width: 140px; vertical-alignment: center; }
                    LineEdit {
                        text <=> root.volume-path;
                        placeholder-text: "/path/to/share";
                        horizontal-stretch: 1;
                        enabled: !root.running;
                    }
                    Button {
                        text: "Browse…";
                        enabled: !root.running;
                        clicked => { root.browse-volume(); }
                    }
                }

                HorizontalBox {
                    Text { text: "Volume Name:"; min-width: 140px; vertical-alignment: center; }
                    LineEdit {
                        text <=> root.volume-name;
                        placeholder-text: "MacShare";
                        horizontal-stretch: 1;
                        enabled: !root.running;
                    }
                }
            }
        }

        HorizontalBox {
            spacing: 8px;

            Rectangle {
                width: 10px;
                height: 10px;
                border-radius: 5px;
                background: root.running ? #22c55e : #9ca3af;
                y: (parent.height - self.height) / 2;
            }

            Text {
                text: root.running ? "Running" : "Stopped";
                vertical-alignment: center;
                horizontal-stretch: 1;
            }

            Button {
                text: root.running ? "Stop" : "Start";
                clicked => { root.start-stop(); }
            }
        }
    }

    // Error dialog — rendered on top of all content when error-message is set
    if root.error-message != "" : Rectangle {
        x: 0; y: 0;
        width: root.width;
        height: root.height;
        background: rgba(0, 0, 0, 0.45);

        Rectangle {
            width: 360px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: #f5f5f5;
            border-radius: 8px;
            drop-shadow-blur: 20px;
            drop-shadow-color: rgba(0, 0, 0, 0.35);

            VerticalBox {
                padding: 20px;
                spacing: 14px;

                Text {
                    text: "Error";
                    font-size: 15px;
                    font-weight: 700;
                    horizontal-alignment: center;
                }

                Text {
                    text: root.error-message;
                    wrap: word-wrap;
                    horizontal-alignment: center;
                }

                HorizontalBox {
                    alignment: center;
                    Button {
                        text: "OK";
                        clicked => { root.error-message = ""; }
                    }
                }
            }
        }
    }
}
