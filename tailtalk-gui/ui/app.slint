import { Button, ComboBox, LineEdit, HorizontalBox, VerticalBox, CheckBox, Palette } from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "TailTalk AFP Server";
    min-width: 400px;
    min-height: 200px;
    preferred-width: 540px;
    preferred-height: 440px;

    in-out property <string> server-name: "TailTalk AFP";
    in property <[string]> ethernet-interfaces;
    in-out property <int> selected-ethernet: 0;
    in property <[string]> tashtalk-ports;
    in-out property <int> selected-tashtalk: 0;
    in-out property <string> volume-path;
    in-out property <string> volume-name: "MacShare";
    in property <bool> running: false;

    // Set from Rust at startup to reflect compiled-in features
    in property <bool> feature-ethertalk: false;
    in property <bool> feature-tashtalk: false;
    in-out property <string> error-message: "";
    in-out property <bool> pcap-enabled: false;
    in-out property <string> pcap-path;
    in-out property <string> info-message: "";

    in-out property <bool> finder-info-visible: false;
    in-out property <string> finder-info-path: "";
    in-out property <string> finder-info-type: "";
    in-out property <string> finder-info-creator: "";

    callback start-stop();
    callback browse-volume();
    callback browse-pcap();
    callback import-stuffit();
    callback import-hfs-image();
    callback inspect-finder-info();
    callback save-finder-info();
    // Returns the input truncated to 4 characters; registered in Rust.
    callback clamp-ostype(string) -> string;

    MenuBar {
        Menu {
            title: "File";
            MenuItem {
                title: "Import StuffIt Archive…";
                activated => { root.import-stuffit(); }
            }
            MenuItem {
                title: "Import HFS Disk Image…";
                activated => { root.import-hfs-image(); }
            }
            MenuItem {
                title: "Inspect Finder Info…";
                activated => { root.inspect-finder-info(); }
            }
        }
    }

    VerticalBox {
        padding: 12px;
        spacing: 8px;

        Rectangle {
            background: Palette.alternate-background;
            border-radius: 8px;

            VerticalBox {
                padding: 12px;
                spacing: 6px;

                // ── Server ────────────────────────────────────────────────────
                Text { text: "Server"; font-weight: 700; }

                HorizontalBox {
                    padding-top: 0; padding-bottom: 0;
                    Text { text: "Server Name"; min-width: 140px; vertical-alignment: center; }
                    LineEdit {
                        text <=> root.server-name;
                        placeholder-text: "TailTalk AFP";
                        horizontal-stretch: 1;
                        enabled: !root.running;

                    }
                }

                if root.feature-ethertalk : HorizontalBox {
                    padding-top: 0; padding-bottom: 0;
                    Text { text: "Ethernet Interface"; min-width: 140px; vertical-alignment: center; }
                    ComboBox {
                        model: root.ethernet-interfaces;
                        current-index <=> root.selected-ethernet;
                        horizontal-stretch: 1;
                        enabled: !root.running;

                    }
                }

                if root.feature-tashtalk : HorizontalBox {
                    padding-top: 0; padding-bottom: 0;
                    Text { text: "TashTalk Port"; min-width: 140px; vertical-alignment: center; }
                    ComboBox {
                        model: root.tashtalk-ports;
                        current-index <=> root.selected-tashtalk;
                        horizontal-stretch: 1;
                        enabled: !root.running;

                    }
                }

                // ── Shared Volume ─────────────────────────────────────────────
                Rectangle { height: 8px; }
                Text { text: "Shared Volume"; font-weight: 700; }

                HorizontalBox {
                    padding-top: 0; padding-bottom: 0;
                    Text { text: "Volume Name"; min-width: 140px; vertical-alignment: center; }
                    LineEdit {
                        text <=> root.volume-name;
                        placeholder-text: "MacShare";
                        horizontal-stretch: 1;
                        enabled: !root.running;

                    }
                }

                HorizontalBox {
                    padding-top: 0; padding-bottom: 0;
                    Text { text: "Volume Path"; min-width: 140px; vertical-alignment: center; }
                    LineEdit {
                        text <=> root.volume-path;
                        placeholder-text: "/path/to/share";
                        horizontal-stretch: 1;
                        enabled: !root.running;

                    }
                    Button {
                        text: "Browse…";
                        enabled: !root.running;
                        clicked => { root.browse-volume(); }
                    }
                }

                // ── Debugging ─────────────────────────────────────────────────
                if root.feature-tashtalk : Rectangle { height: 8px; }
                if root.feature-tashtalk : Text { text: "Debugging"; font-weight: 700; }

                if root.feature-tashtalk : HorizontalBox {
                    padding-top: 0; padding-bottom: 0;
                    Text { text: "Capture PCAP"; min-width: 140px; vertical-alignment: center; }
                    CheckBox {
                        checked <=> root.pcap-enabled;
                        enabled: !root.running;
                    }
                    Rectangle { horizontal-stretch: 1; }
                }

                if root.feature-tashtalk : HorizontalBox {
                    padding-top: 0; padding-bottom: 0;
                    Text { text: "PCAP File"; min-width: 140px; vertical-alignment: center; }
                    LineEdit {
                        text <=> root.pcap-path;
                        placeholder-text: "Path to output .pcap file";
                        horizontal-stretch: 1;
                        enabled: !root.running && root.pcap-enabled;
                    }
                    Button {
                        text: "Browse…";
                        enabled: !root.running && root.pcap-enabled;
                        clicked => { root.browse-pcap(); }
                    }
                }
            }
        }

        HorizontalBox {
            spacing: 8px;

            Rectangle {
                width: 10px;
                height: 10px;
                border-radius: 5px;
                background: root.running ? #22c55e : #9ca3af;
                y: (parent.height - self.height) / 2;
            }

            Text {
                text: root.running ? "Running" : "Stopped";
                vertical-alignment: center;
                horizontal-stretch: 1;
            }

            Button {
                text: root.running ? "Stop" : "Start";
                enabled: root.running || (
                    root.server-name != ""
                    && root.volume-name != ""
                    && root.volume-path != ""
                    && ((root.feature-ethertalk && root.selected-ethernet != 0)
                        || (root.feature-tashtalk && root.selected-tashtalk != 0))
                );
                clicked => { root.start-stop(); }
            }
        }
    }

    // Error dialog — rendered on top of all content when error-message is set
    if root.error-message != "" : Rectangle {
        x: 0; y: 0;
        width: root.width;
        height: root.height;
        background: rgba(0, 0, 0, 0.45);

        Rectangle {
            width: 360px;
            height: dialog-content.preferred-height;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: #f5f5f5;
            border-radius: 8px;
            drop-shadow-blur: 20px;
            drop-shadow-color: rgba(0, 0, 0, 0.35);

            dialog-content := VerticalBox {
                padding: 20px;
                spacing: 14px;

                Text {
                    text: "Error";
                    font-size: 15px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    color: #1a1a1a;
                }

                Text {
                    text: root.error-message;
                    wrap: word-wrap;
                    horizontal-alignment: center;
                    color: #1a1a1a;
                }

                HorizontalBox {
                    alignment: center;
                    Button {
                        text: "OK";
                        clicked => { root.error-message = ""; }
                    }
                }
            }
        }
    }

    // Finder Info dialog — file type and creator editor
    if root.finder-info-visible : Rectangle {
        x: 0; y: 0;
        width: root.width;
        height: root.height;
        background: rgba(0, 0, 0, 0.45);

        Rectangle {
            width: 380px;
            height: fi-content.preferred-height;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: #f5f5f5;
            border-radius: 8px;
            drop-shadow-blur: 20px;
            drop-shadow-color: rgba(0, 0, 0, 0.35);

            fi-content := VerticalBox {
                padding: 20px;
                spacing: 14px;

                Text {
                    text: "Finder Info";
                    font-size: 15px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    color: #1a1a1a;
                }

                Text {
                    text: root.finder-info-path;
                    wrap: word-wrap;
                    horizontal-alignment: center;
                    color: #555555;
                    font-size: 11px;
                }

                HorizontalBox {
                    Text { text: "File Type:"; min-width: 80px; vertical-alignment: center; color: #1a1a1a; }
                    LineEdit {
                        text <=> root.finder-info-type;
                        placeholder-text: "    ";
                        horizontal-stretch: 1;
                        edited(t) => { root.finder-info-type = root.clamp-ostype(t); }
                    }
                }

                HorizontalBox {
                    Text { text: "Creator:"; min-width: 80px; vertical-alignment: center; color: #1a1a1a; }
                    LineEdit {
                        text <=> root.finder-info-creator;
                        placeholder-text: "    ";
                        horizontal-stretch: 1;
                        edited(t) => { root.finder-info-creator = root.clamp-ostype(t); }
                    }
                }

                HorizontalBox {
                    alignment: center;
                    spacing: 8px;
                    Button {
                        text: "Cancel";
                        clicked => { root.finder-info-visible = false; }
                    }
                    Button {
                        text: "Save";
                        clicked => { root.save-finder-info(); }
                    }
                }
            }
        }
    }

    // Info dialog — rendered on top when info-message is set (e.g. successful import)
    if root.info-message != "" : Rectangle {
        x: 0; y: 0;
        width: root.width;
        height: root.height;
        background: rgba(0, 0, 0, 0.45);

        Rectangle {
            width: 360px;
            height: info-content.preferred-height;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: #f5f5f5;
            border-radius: 8px;
            drop-shadow-blur: 20px;
            drop-shadow-color: rgba(0, 0, 0, 0.35);

            info-content := VerticalBox {
                padding: 20px;
                spacing: 14px;

                Text {
                    text: "Done";
                    font-size: 15px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    color: #1a1a1a;
                }

                Text {
                    text: root.info-message;
                    wrap: word-wrap;
                    horizontal-alignment: center;
                    color: #1a1a1a;
                }

                HorizontalBox {
                    alignment: center;
                    Button {
                        text: "OK";
                        clicked => { root.info-message = ""; }
                    }
                }
            }
        }
    }
}
